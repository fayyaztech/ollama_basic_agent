# ─────────────────────────────────────────────
# Ollama Agent - Environment Configuration
# Copy this file to .env and edit as needed:
#   cp .env.example .env
# ─────────────────────────────────────────────

# Ollama server URL
OLLAMA_HOST=http://localhost:11434

# Max reasoning steps per user message
MAX_STEPS=5

# Number of conversation turns to keep in context
HISTORY_WINDOW=14

# Log file path
LOG_FILE=agent.log

# Log level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# Memory file path
MEMORY_FILE=memory.json

# Debug mode: if true, prints step-by-step reasoning in terminal
# If false, only the final AI response is shown
DEBUG=false
